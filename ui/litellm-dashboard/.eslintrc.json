        "src/components/policies/impact_popover.tsx",
        "src/components/DeletedKeysPage/DeletedKeysPage.tsx",
        "src/components/DeletedTeamsPage/DeletedTeamsPage.tsx"
      ],
      "rules": {
        "litellm-ui/no-banned-ui-imports": "off",
        "litellm-ui/no-raw-tailwind-colors": "off"
      }
    },
    {
      "files": ["**/*.test.{ts,tsx}", "**/*.spec.{ts,tsx}", "tests/**/*.{ts,tsx}", "e2e_tests/**/*.{ts,tsx}"],
      "rules": {
        "litellm-ui/no-banned-ui-imports": "off",
        "litellm-ui/no-raw-tailwind-colors": "off"
      }
    }
  ]
}
