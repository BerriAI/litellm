# chartsnap: snapshot_version=v3
---
# Source: litellm-helm/templates/extra-resources.yaml
apiVersion: v1
kind: Secret
metadata:
  name: litellm-env-secret
name: litellm-env-secret
stringData:
  POSTGRES_DB: litellm-db
  POSTGRESQL_HOST: postgres.postgres-namespace.cluster.svc.local
  POSTGRESQL_PASSWORD: secretpassword
  POSTGRESQL_PORT: "55432"
  POSTGRESQL_USER: litellm
---
# Source: litellm-helm/templates/configmap-litellm.yaml
apiVersion: v1
kind: ConfigMap
metadata:
  name: chartsnap-litellm-config
data:
  config.yaml: |
    general_settings:
      master_key: os.environ/PROXY_MASTER_KEY
    model_list:
    - litellm_params:
        api_key: eXaMpLeOnLy
        model: gpt-3.5-turbo
      model_name: gpt-3.5-turbo
    - litellm_params:
        api_base: https://exampleopenaiendpoint-production.up.railway.app/
        api_key: fake-key
        model: openai/fake
      model_name: fake-openai-endpoint
---
# Source: litellm-helm/templates/service.yaml
apiVersion: v1
kind: Service
metadata:
  name: chartsnap-litellm
  labels:
    helm.sh/chart: litellm-helm-1.1.0
    app.kubernetes.io/name: litellm
    app.kubernetes.io/instance: chartsnap
    app.kubernetes.io/version: "v1.85.1"
    app.kubernetes.io/managed-by: Helm
spec:
  type: ClusterIP
  ports:
  - port: 4000
    targetPort: http
    protocol: TCP
    name: http
  selector:
    app.kubernetes.io/name: litellm
    app.kubernetes.io/instance: chartsnap
---
# Source: litellm-helm/templates/deployment.yaml
apiVersion: apps/v1
kind: Deployment
metadata:
  name: chartsnap-litellm
  labels:
    helm.sh/chart: litellm-helm-1.1.0
    app.kubernetes.io/name: litellm
    app.kubernetes.io/instance: chartsnap
    app.kubernetes.io/version: "v1.85.1"
    app.kubernetes.io/managed-by: Helm
spec:
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: litellm
      app.kubernetes.io/instance: chartsnap
  template:
    metadata:
      annotations:
        checksum/config: 67358420a4cbfe4c33214fc83c1b79ce9b69d3b605b0cfa2846194e14deeb38d
      labels:
        helm.sh/chart: litellm-helm-1.1.0
        app.kubernetes.io/name: litellm
        app.kubernetes.io/instance: chartsnap
        app.kubernetes.io/version: "v1.85.1"
        app.kubernetes.io/managed-by: Helm
    spec:
      serviceAccountName: default
      securityContext: {}
      containers:
      - name: litellm
        securityContext: {}
        image: "ghcr.io/berriai/litellm-database:v1.85.1"
        imagePullPolicy: Always
        env:
        - name: HOST
          value: "0.0.0.0"
        - name: PORT
          value: "4000"
        - name: DATABASE_USERNAME
          valueFrom:
            secretKeyRef:
              name: postgres
              key: username
        - name: DATABASE_PASSWORD
          valueFrom:
            secretKeyRef:
              name: postgres
              key: password
        - name: DATABASE_HOST
          value: localhost
        - name: DATABASE_NAME
          value: litellm
        - name: DATABASE_URL
          value: "postgresql://$(POSTGRESQL_USER):$(POSTGRESQL_PASSWORD)@$(POSTGRESQL_HOST):$(POSTGRESQL_PORT)/$(POSTGRESQL_DB)"
        - name: PROXY_MASTER_KEY
          valueFrom:
            secretKeyRef:
              name: litellm-masterkey
              key: masterkey
        - name: LITELLM_LOG
          value: "INFO"
        # Schema updates are owned by the dedicated migrations Job; skip
        # the proxy's startup `prisma db push` so N replicas don't race
        # one DB on every rollout. Placed last (after envVars and
        # extraEnvVars) so this override can't be silently shadowed by a
        # user-supplied DISABLE_SCHEMA_UPDATE under last-wins duplicate-env
        # semantics — same pattern the migrations Job uses.
        - name: DISABLE_SCHEMA_UPDATE
          value: "true"
        envFrom:
        - secretRef:
            name: litellm-env-secret
        - configMapRef:
            name: litellm-env-configmap
        args:
        - --config
        - /etc/litellm/config.yaml
        ports:
        - name: http
          containerPort: 4000
          protocol: TCP
        livenessProbe:
          httpGet:
            path: "/health/liveliness"
            port: "http"
          initialDelaySeconds: 0
          periodSeconds: 15
          timeoutSeconds: 5
          successThreshold: 1
          failureThreshold: 5
        readinessProbe:
          httpGet:
            path: "/health/readiness"
            port: "http"
          initialDelaySeconds: 0
          periodSeconds: 10
          timeoutSeconds: 5
          successThreshold: 1
          failureThreshold: 3
        startupProbe:
          httpGet:
            path: "/health/readiness"
            port: "http"
          initialDelaySeconds: 0
          periodSeconds: 10
          timeoutSeconds: 5
          successThreshold: 1
          failureThreshold: 30
        resources: {}
        volumeMounts:
        - name: litellm-config
          mountPath: /etc/litellm/config.yaml
          subPath: config.yaml
      volumes:
      - name: litellm-config
        configMap:
          name: chartsnap-litellm-config
          items:
          - key: config.yaml
            path: "config.yaml"
      terminationGracePeriodSeconds: 90
---
# Source: litellm-helm/templates/migrations-job.yaml
# This job runs the Prisma migrations for the LiteLLM DB.
apiVersion: batch/v1
kind: Job
metadata:
  name: chartsnap-litellm-migrations
  labels:
    helm.sh/chart: litellm-helm-1.1.0
    app.kubernetes.io/name: litellm
    app.kubernetes.io/instance: chartsnap
    app.kubernetes.io/version: "v1.85.1"
    app.kubernetes.io/managed-by: Helm
  annotations:
    argocd.argoproj.io/hook: PreSync
    argocd.argoproj.io/hook-delete-policy: BeforeHookCreation
    checksum/config: bb05db2b733d4add910e27005484e75184e8ad01b632f794982918f6b984e5fe
spec:
  template:
    metadata:
      labels:
        helm.sh/chart: litellm-helm-1.1.0
        app.kubernetes.io/name: litellm
        app.kubernetes.io/instance: chartsnap
        app.kubernetes.io/version: "v1.85.1"
        app.kubernetes.io/managed-by: Helm
      annotations:
    spec:
      serviceAccountName: default
      containers:
      - name: prisma-migrations
        image: "ghcr.io/berriai/litellm-database:v1.85.1"
        imagePullPolicy: Always
        securityContext: {}
        command: ["python", "litellm/proxy/prisma_migration.py"]
        workingDir: "/app"
        env:
        - name: DATABASE_USERNAME
          valueFrom:
            secretKeyRef:
              name: postgres
              key: username
        - name: DATABASE_PASSWORD
          valueFrom:
            secretKeyRef:
              name: postgres
              key: password
        - name: DATABASE_HOST
          value: localhost
        - name: DATABASE_NAME
          value: litellm
        - name: DATABASE_URL
          value: "postgresql://$(POSTGRESQL_USER):$(POSTGRESQL_PASSWORD)@$(POSTGRESQL_HOST):$(POSTGRESQL_PORT)/$(POSTGRESQL_DB)"
        - name: DISABLE_SCHEMA_UPDATE
          value: "false" # always run the migration from the Helm PreSync hook, override the value set
        envFrom:
        - secretRef:
            name: litellm-env-secret
        - configMapRef:
            name: litellm-env-configmap
      restartPolicy: OnFailure
  ttlSecondsAfterFinished: 120
  backoffLimit: 4
---
# Source: litellm-helm/templates/tests/test-connection.yaml
apiVersion: v1
kind: Pod
metadata:
  name: "chartsnap-litellm-test-connection"
  labels:
    helm.sh/chart: litellm-helm-1.1.0
    app.kubernetes.io/name: litellm
    app.kubernetes.io/instance: chartsnap
    app.kubernetes.io/version: "v1.85.1"
    app.kubernetes.io/managed-by: Helm
  annotations:
    "helm.sh/hook": test
spec:
  containers:
  - name: wget
    image: busybox
    command: ['sh', '-c']
    args:
    - |
      # Wait for a bit to allow the service to be ready
      sleep 10
      # Try multiple times with a delay between attempts
      for i in $(seq 1 30); do
        wget -T 5 "chartsnap-litellm:4000/health/readiness" && exit 0
        echo "Attempt $i failed, waiting..."
        sleep 2
      done
      exit 1
  restartPolicy: Never
---
# Source: litellm-helm/templates/tests/test-env-vars.yaml
apiVersion: v1
kind: Pod
metadata:
  name: "chartsnap-litellm-env-test"
  labels:
    helm.sh/chart: litellm-helm-1.1.0
    app.kubernetes.io/name: litellm
    app.kubernetes.io/instance: chartsnap
    app.kubernetes.io/version: "v1.85.1"
    app.kubernetes.io/managed-by: Helm
  annotations:
    "helm.sh/hook": test
spec:
  containers:
  - name: test
    image: busybox
    command: ['sh', '-c']
    args:
    - |
      # Test DD_ENV
      if [ "$DD_ENV" != "dev_helm" ]; then
        echo "❌ Environment variable DD_ENV mismatch. Expected: dev_helm, Got: $DD_ENV"
        exit 1
      fi
      echo "✅ Environment variable DD_ENV matches expected value: $DD_ENV"

      # Test DD_SERVICE
      if [ "$DD_SERVICE" != "litellm" ]; then
        echo "❌ Environment variable DD_SERVICE mismatch. Expected: litellm, Got: $DD_SERVICE"
        exit 1
      fi
      echo "✅ Environment variable DD_SERVICE matches expected value: $DD_SERVICE"

      # Test USE_DDTRACE
      if [ "$USE_DDTRACE" != "true" ]; then
        echo "❌ Environment variable USE_DDTRACE mismatch. Expected: true, Got: $USE_DDTRACE"
        exit 1
      fi
      echo "✅ Environment variable USE_DDTRACE matches expected value: $USE_DDTRACE"
    env:
    - name: DD_ENV
      value:
    - name: DD_SERVICE
      value:
    - name: USE_DDTRACE
      value:
  restartPolicy: Never
