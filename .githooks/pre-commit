#!/usr/bin/env bash
#
# pre-commit — fast lint gate on staged litellm/ Python files.
#
# Runs ruff format-check and ruff check only on files staged for this commit,
# so the check stays quick regardless of repo size.
#
# Bypass: git commit --no-verify

set -eu

# Collect staged Python files inside litellm/ (excluding enterprise/).
staged=$(git diff --cached --name-only --diff-filter=ACMR -- 'litellm/**/*.py' \
  | grep -v '^litellm/enterprise/' || true)

if [ -z "$staged" ]; then
  exit 0
fi

echo "pre-commit: checking $(echo "$staged" | wc -l | tr -d ' ') staged litellm Python file(s)..."

# 1. ruff format
echo "$staged" | xargs uv run --no-sync ruff format --check --line-length 88 || {
  echo ""
  echo "ruff format failed. Run 'task format' (from local-dev/) or:"
  echo "  echo '$staged' | xargs uv run ruff format --line-length 88"
  exit 1
}

# 2. ruff lint
echo "$staged" | xargs uv run --no-sync ruff check || {
  echo ""
  echo "ruff check failed. Fix the issues above, then re-stage."
  exit 1
}

echo "pre-commit: lint OK"
