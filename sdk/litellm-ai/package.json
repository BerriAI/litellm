{
  "name": "litellm",
  "version": "0.1.0",
  "description": "Typed TypeScript SDK for the LiteLLM AI Gateway",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "generate": "openapi-ts",
    "build": "tsc -p tsconfig.build.json",
    "test": "npx vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "litellm",
    "openai",
    "llm",
    "ai",
    "sdk",
    "typescript",
    "api-client"
  ],
  "license": "MIT",
  "devDependencies": {
    "@hey-api/openapi-ts": "0.97.2",
    "typescript": "5.8.3",
    "vitest": "3.2.1"
  },
  "peerDependencies": {
    "typescript": ">=5.0"
  }
}
