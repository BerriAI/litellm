{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "LiteLLM proxy (debug)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/litellm/proxy/proxy_cli.py",
            "cwd": "${workspaceFolder}",
            "args": [
                "--host",
                "0.0.0.0",
                "--config",
                "dev_config.yaml",
                "--port",
                "4000",
                "--num_workers",
                "1"
            ],
            "console": "integratedTerminal",
            "justMyCode": false
        }
    ]
}