# Build on top of the published stable image.
# Only adds new Mavvrik files + patches proxy_server.py and custom_logger_registry.py.
FROM ghcr.io/berriai/litellm:main-stable

WORKDIR /app

# New integration files (don't exist in base image at all)
COPY litellm/integrations/mavvrik/                        /app/litellm/integrations/mavvrik/
COPY litellm/types/integrations/mavvrik.py                /app/litellm/types/integrations/mavvrik.py
COPY litellm/types/proxy/mavvrik_endpoints.py             /app/litellm/types/proxy/mavvrik_endpoints.py
COPY litellm/proxy/spend_tracking/mavvrik_endpoints.py    /app/litellm/proxy/spend_tracking/mavvrik_endpoints.py
COPY litellm/integrations/focus/                          /app/litellm/integrations/focus/

# Append only the Mavvrik constants that don't exist in the base image's constants.py.
# We do NOT replace the full file — the stable image's constants.py may have entries
# that our main-branch version omits, breaking other modules.
RUN grep -q "MAVVRIK_EXPORT_INTERVAL_MINUTES" /app/litellm/constants.py || \
    printf '\n# Mavvrik integration constants\nMAVVRIK_EXPORT_INTERVAL_MINUTES: int = int(os.getenv("MAVVRIK_EXPORT_INTERVAL_MINUTES", 60))\nMAVVRIK_EXPORT_USAGE_DATA_JOB_NAME: str = "mavvrik_export_usage_data"\nMAVVRIK_MAX_FETCHED_DATA_RECORDS: int = 100000\n' \
    >> /app/litellm/constants.py

# Patch proxy_server.py:
# 1. Insert mavvrik router import after the vantage_router import
# 2. Append router registration at end of file
# 3. Inject Mavvrik background job into _initialize_spend_tracking_background_jobs
RUN grep -q "mavvrik_router" /app/litellm/proxy/proxy_server.py || ( \
    sed -i 's|from litellm.proxy.spend_tracking.vantage_endpoints import router as vantage_router|from litellm.proxy.spend_tracking.vantage_endpoints import router as vantage_router\nfrom litellm.proxy.spend_tracking.mavvrik_endpoints import router as mavvrik_router|' /app/litellm/proxy/proxy_server.py && \
    echo "app.include_router(mavvrik_router)" >> /app/litellm/proxy/proxy_server.py \
)

RUN grep -q "is_mavvrik_setup" /app/litellm/proxy/proxy_server.py || \
    python3 -c "\
with open('/app/litellm/proxy/proxy_server.py', 'r') as f:\
    content = f.read();\
mavvrik_block = '''\n        ########################################################\n        # Mavvrik Background Job\n        ########################################################\n        from litellm.integrations.mavvrik.mavvrik import MavvrikLogger\n        from litellm.proxy.spend_tracking.mavvrik_endpoints import is_mavvrik_setup\n\n        if await is_mavvrik_setup():\n            await MavvrikLogger.init_mavvrik_background_job(scheduler=scheduler)\n''';\
target = '        ########################################################\n        # Prometheus Background Job';\
content = content.replace(target, mavvrik_block + '\n' + target, 1);\
open('/app/litellm/proxy/proxy_server.py', 'w').write(content)\
"

# Patch custom_logger_registry.py and __init__.py to register "mavvrik" as a first-class
# callback. This allows users to set callbacks: ["mavvrik"] in config.yaml (same as
# cloudzero/vantage) and LiteLLM will auto-instantiate MavvrikLogger — no /mavvrik/init needed.
RUN grep -q '"mavvrik"' /app/litellm/litellm_core_utils/custom_logger_registry.py || \
    python3 -c "\
with open('/app/litellm/litellm_core_utils/custom_logger_registry.py', 'r') as f:\
    content = f.read();\
content = content.replace(\
    'from litellm.integrations.vantage.vantage_logger import VantageLogger',\
    'from litellm.integrations.vantage.vantage_logger import VantageLogger\nfrom litellm.integrations.mavvrik.mavvrik import MavvrikLogger'\
).replace(\
    '\"vantage\": VantageLogger,',\
    '\"vantage\": VantageLogger,\n        \"mavvrik\": MavvrikLogger,'\
);\
open('/app/litellm/litellm_core_utils/custom_logger_registry.py', 'w').write(content)\
"

# Patch __init__.py to add "mavvrik" to _custom_logger_compatible_callbacks_literal.
# The stable image's __init__.py does not include it, causing "mavvrik" to be treated as
# a file path by get_instance_fn and crashing on startup.
RUN grep -q '"mavvrik"' /app/litellm/__init__.py || \
    sed -i 's|"cloudzero",|"cloudzero",\n    "mavvrik",|' /app/litellm/__init__.py
